<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vulnerable Lab</title>
        <link rel="stylesheet" href="/css/style.css">
    <style>
        .vuln-link { color: #e74c3c; }
        .nav-links {
            background: #f8f9fa;
            border-radius: 4px;
            padding: 10px;
            margin: 1rem 0;
        }
        .user-status { float: right; }
    </style>
        <!-- Bootstrap 5 CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
        <!-- Custom CSS -->
        <link rel="stylesheet" href="/css/style.css">
</head>
<body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-danger">
            <div class="container">
                <a class="navbar-brand" href="/">Vulnerable Lab</a>
                <div class="ms-auto">
                    <% if (user) { %>
                        <span class="text-white me-2"><i class="fas fa-user"></i> <%= user.username %></span>
                        <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
                    <% } else { %>
                        <a href="/register" class="btn btn-outline-light btn-sm me-2">Sign Up</a>
                        <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
                    <% } %>
                </div>
            </div>
        </nav>

    <div class="app-container">
            <div class="py-4">
                <h1 class="mb-3">Vulnerabilities</h1>

                <div class="row">
                    <div class="col-md-6">
                        <div class="card mb-3">
                            <div class="card-body">
                                <h5>Authentication & Access</h5>
                                <a href="/vuln/broken-access" class="vuln-link">Broken Access Control (Profile demo)</a>
                                <a href="/vuln/sensitive" class="vuln-link">Sensitive Data Exposure</a>
                                <a href="/vuln/auth" class="vuln-link">Broken Authentication (login issues)</a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card mb-3">
                            <div class="card-body">
                                <h5>Injection & Server</h5>
                                <a href="/vuln/sqli" class="vuln-link">SQL Injection (Search)</a>
                                <a href="/vuln/xss" class="vuln-link">Cross-Site Scripting (XSS)</a>
                                <a href="/vuln/csrf" class="vuln-link">CSRF (Transfer)</a>
                                <a href="/vuln/ssrf" class="vuln-link">SSRF (Fetch)</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="warning-box">
                    <strong>⚠️ Educational Only:</strong> This app intentionally demonstrates security weaknesses. Do not deploy this code to production.
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>