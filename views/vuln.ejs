<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof name !== 'undefined' ? name : 'View' %> - Vulnerable Lab</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
      .data-display { padding:1rem; border-radius:8px; }
      .description { color:#6c757d; font-style:italic; }
    </style>
</head>
<body>
        <div class="app-container py-4">
        <h1><%= typeof name !== 'undefined' ? name : 'View' %></h1>

        <% if (typeof description !== 'undefined') { %>
            <p class="description"><%= description %></p>
        <% } %>

        <div class="data-display card">
            <div class="card-body">
                <pre><%= JSON.stringify(data, null, 2) %></pre>
            </div>
        </div>

        <p class="mt-3"><a href="/">← Back to Home</a></p>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>